app_name      = fksrv
app_port      = 8884
app_host      = 0.0.0.0
app_debug     = False
app_reload    = False
app_workers   = 4
app_timeout   = 60
# 日记级别: debug | info | warning | error | critical
app_loglevel  = info
# 输出位置: - | logs/app.log | None
app_accesslog = -
app_pidfile   = fksrv.pid
app_daemon    = True
app_keyfile   = cert/server.key
app_certfile  = cert/server.crt
