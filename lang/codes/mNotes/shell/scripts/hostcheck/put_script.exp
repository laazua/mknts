#!/usr/bin/expect

## 上传脚本

set ipaddres [lindex $argv 0]
set username [lindex $argv 1]
set password [lindex $argv 2]
set scriname [lindex $argv 3]
set timeout 20

spawn scp $scriname $username@$ipaddres:/tmp/
expect {
    "yes/no" {send "yes\r";exp_continue}
    "password" {send "$password\r"}
}
expect eof
