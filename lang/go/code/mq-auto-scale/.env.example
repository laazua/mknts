# 应用配置
APP_NAME=mq-auto-scale
APP_VERSION=1.0.0
PORT=8080
DEBUG=true
TIMEOUT=30.5

# 服务器配置
ALLOWED_HOSTS=["localhost", "127.0.0.1", "example.com"]
ALLOWED_PORTS=[3000, 8080, 9090]

# 数据库配置
DATABASE={host: "localhost", port: 5432, name: "mydb", user: "admin"}
CACHE={enabled: true, ttl: 3600, servers: ["redis1:6379", "redis2:6379"]}

# 安全配置
API_SECRET="my-secret-key!@#$%"
JWT_SECRET='jwt-secret-123'


# .env 文件示例
APP_NAME=MyApp

# 多行列表格式1（带尾随逗号）
QUEUE_NAMES=[
    "ama-message-pull",
    "another-queue",
    "third-queue",
]

# 多行列表格式2（无尾随逗号）
ALLOWED_HOSTS=[
    "localhost",
    "127.0.0.1",
    "example.com"
]

# 多行对象
DATABASE={
    host: "localhost",
    port: 5432,
    name: "mydb",
    options: {
        max_connections: 100,
        timeout: "30s"
    }
}

# 嵌套列表
MATRIX=[
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]

# 混合类型列表
CONFIG=[
    8080,
    "localhost",
    true,
    {key: "value"}
]

# 消费者队列配置
CONSUMER_QUEUES=[
    { name: 'ama.message.pull', vhost: 'mq-auto-scale', config: 'consumer.ini', path: '/etc/supervisord.d/' },
]
