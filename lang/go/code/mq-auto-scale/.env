# 全局配置
CHECK_INTERVAL=3s
COOLDOWN_PERIOD=30s

# 资源监控
ENABLE_RESOURCE_MONITOR=true
CPU_THRESHOLD=80.0
MEM_THRESHOLD=85.0
RESOURCE_CHECK_INTERVAL=5s
SCALE_UP_BLOCK_WAIT=30s

# 日志
DEBUG=false
LOG_FORMAT=text

# Supervisor 配置
SUPERVISOR_URL=http://localhost:9001/RPC2
SUPERVISOR_USER=admin
SUPERVISOR_PASSWORD=123456
SUPERVISOR_TIMEOUT=10s
SUPERVISOR_CONFIG_DIR=/etc/supervisord.d/

# mq连接配置
MQ_HOST=192.168.165.88
MQ_PORT=5672
MQ_USER=admin
MQ_PASSWD=123456
MQ_VHOST=mq-auto-scale
MQ_TIMEOUT=3s
MQ_MAX_RETRIES=3
MQ_RETRY_DELAY=2s
MQ_USE_SSL=false

# mq消费者队列配置
CONSUMER_QUEUES=[
    { name: 'ama.message.pull', vhost: 'mq-auto-scale', config: 'consumer.ini', path: '/etc/supervisord.d/' },
]

