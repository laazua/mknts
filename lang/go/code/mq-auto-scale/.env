# 全局配置
CHECK_INTERVAL=3s
COOLDOWN_PERIOD=30s

# 资源监控
ENABLE_RESOURCE_MONITOR=true
CPU_THRESHOLD=80.0
MEM_THRESHOLD=85.0
RESOURCE_CHECK_INTERVAL=5s
SCALE_UP_BLOCK_WAIT=30s

# 日志
DEBUG=false
LOG_FORMAT=text

# Supervisor 配置
SUPERVISOR_URL=http://localhost:9001/RPC2
SUPERVISOR_USER=admin
SUPERVISOR_PASSWORD=123456
SUPERVISOR_TIMEOUT=10s
SUPERVISOR_CONFIG_DIR=/etc/supervisord.d/

# 连接配置
MQ_HOST=192.168.165.88
MQ_PORT=5672
MQ_USER=admin
MQ_PASSWD=123456
MQ_VHOST=/
MQ_TIMEOUT=5s
MQ_MAX_RETRIES=3
MQ_RETRY_DELAY=2s
MQ_USE_SSL=false

# 队列配置
QUEUE_NAMES=[
    "ama-message-pull",
    "another-queue",
    "third-queue",
]

# ama-message-pull 队列配置
ama-message-pull_PROGRAM=ama-message-pull
ama-message-pull_MIN_CONSUMER=1
ama-message-pull_MAX_CONSUMER=15
ama-message-pull_SCALE_UP_THRESHOLD=100
ama-message-pull_SCALE_DOWN_THRESHOLD=10

# another-queue 队列配置
another-queue_PROGRAM=another-queue
another-queue_MIN_CONSUMER=2
another-queue_MAX_CONSUMER=10
another-queue_SCALE_UP_THRESHOLD=50
another-queue_SCALE_DOWN_THRESHOLD=5

# third-queue 队列配置
third-queue_PROGRAM=third-queue
third-queue_MIN_CONSUMER=1
third-queue_MAX_CONSUMER=8
third-queue_SCALE_UP_THRESHOLD=200
third-queue_SCALE_DOWN_THRESHOLD=20
